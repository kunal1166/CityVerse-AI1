# ============================================================
# CityVerse AI - Environment Configuration
# ============================================================
# Setup:  cp .env.example .env.local   then paste your key below.
#
# The app also runs with NO key at all - it falls back to a
# built-in offline briefing engine, so a demo never hard-fails.
# ============================================================

AI_PROVIDER=groq

# Get a free key at https://console.groq.com/keys
GROQ_API_KEY= "Enter_your_Groq_API_key_here"


# ---- Live data providers -----------------------------------

# Weather + Air Quality: Open-Meteo. NO KEY NEEDED. Already working.

# Traffic: TomTom. Free key from https://developer.tomtom.com
# Leave blank to keep using mock traffic - nothing breaks.
TOMTOM_API_KEY= "Enter_your_TomTom_API_key_here"


# ---- Optional ----------------------------------------------

# Override the model. Default: llama-3.3-70b-versatile
# Use llama-3.1-8b-instant if you hit rate limits mid-demo.
# AI_MODEL=

# Milliseconds before a slow AI call gives up and uses the
# offline briefing. Default: 20000
# AI_TIMEOUT_MS=20000

# Server port. Default: 3000
# PORT=3000


# ---- Other supported providers (optional) -------------------
# The app is provider-agnostic. To switch, change AI_PROVIDER
# above and set the matching key - no code changes needed.
#
#   AI_PROVIDER=anthropic    ANTHROPIC_API_KEY=      # console.anthropic.com
#   AI_PROVIDER=openai       OPENAI_API_KEY=         # platform.openai.com/api-keys
#   AI_PROVIDER=openrouter   OPENROUTER_API_KEY=     # openrouter.ai/keys
#   AI_PROVIDER=ollama       (no key - fully local)  # ollama.com
#   AI_PROVIDER=none         (offline briefing engine)
